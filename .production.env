# =============================================================================
# PMO Project Initiation Portal — Production Environment Variables
# =============================================================================
# This file documents the production environment configuration.
# In real deployments, set these as actual environment variables
# (Docker secrets, Azure App Service Application Settings, Render env vars, etc.)
# DO NOT store real secrets in this file.
# =============================================================================

NODE_ENV=production
PORT=45821

# Azure AD
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
USER_EMAIL=
SECRET_ID=
OBJECT_ID=

# SharePoint
SHAREPOINT_SITE_URL=https://techdefencelabsolutions.sharepoint.com/sites/pmo

# CORS (local LAN access)
ALLOWED_ORIGINS=http://localhost:45821

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_INITIATE_WINDOW_MS=60000
RATE_LIMIT_INITIATE_MAX=10

# Health Check
HEALTH_CHECK_TIMEOUT_MS=5000

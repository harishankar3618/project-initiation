# =============================================================================
# PMO Project Initiation Portal — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=45821
NODE_ENV=production

# -----------------------------------------------------------------------------
# Azure AD Application Registration
# -----------------------------------------------------------------------------
TENANT_ID=
CLIENT_ID=
CLIENT_SECRET=
USER_EMAIL=
SECRET_ID=
OBJECT_ID=

# -----------------------------------------------------------------------------
# SharePoint
# -----------------------------------------------------------------------------
# SharePoint site URL (e.g. https://contoso.sharepoint.com/sites/pmo)
SHAREPOINT_SITE_URL=https://techdefencelabsolutions.sharepoint.com/sites/pmo

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS.
# For local LAN access, you may want to add your machine's IP.
# Example: ALLOWED_ORIGINS=http://localhost:45821,http://192.168.1.100:45821
ALLOWED_ORIGINS=http://localhost:45821

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_INITIATE_WINDOW_MS=60000
RATE_LIMIT_INITIATE_MAX=10

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
HEALTH_CHECK_TIMEOUT_MS=5000

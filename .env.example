# =============================================================================
# PMO Project Initiation Portal — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

# -----------------------------------------------------------------------------
# Azure AD Application Registration
# -----------------------------------------------------------------------------
# tenant-id: Azure AD tenant GUID (found in Azure Portal > Azure AD > Overview)
TENANT_ID=

# client-id: Application (client) ID of the registered app
CLIENT_ID=

# client-secret: Client secret value (NOT the secret ID) from Azure AD App Registration
CLIENT_SECRET=

# user-email: Primary user / service account email (for logging / context)
USER_EMAIL=

# secret-id: Azure AD App Registration secret identifier (for rotation tracking)
SECRET_ID=

# object-id: Azure AD App Registration object ID (for management operations)
OBJECT_ID=

# -----------------------------------------------------------------------------
# SharePoint
# -----------------------------------------------------------------------------
# SharePoint site URL (e.g. https://contoso.sharepoint.com/sites/pmo)
SHAREPOINT_SITE_URL=https://techdefencelabsolutions.sharepoint.com/sites/pmo

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS.
# Example: ALLOWED_ORIGINS=https://portal.contoso.com,https://admin.contoso.com
# Leave empty to block all origins (recommended for production behind a proxy).
ALLOWED_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Maximum requests per IP per window (in minutes) for general endpoints
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Maximum requests per IP per window for the initiate endpoint (more restrictive)
RATE_LIMIT_INITIATE_WINDOW_MS=60000
RATE_LIMIT_INITIATE_MAX=10

# -----------------------------------------------------------------------------
# Health Check
# -----------------------------------------------------------------------------
# Timeout in milliseconds for downstream dependency checks in /api/health
HEALTH_CHECK_TIMEOUT_MS=5000
